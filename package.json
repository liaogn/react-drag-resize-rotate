{
  "name": "@liaogn/react-drag-resize-rotate",
  "version": "1.0.0",
  "description": "React component for dragging, resizing, and rotating DOM elements. Simple, dependency-free, supports nesting / aspect-lock / flipping.",
  "private": false,
  "main": "./dist/index.umd.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.umd.cjs"
    },
    "./style.css": "./dist/style.css",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "keywords": [
    "react",
    "drag",
    "resize",
    "rotate",
    "draggable",
    "resizable",
    "rotatable"
  ],
  "author": "liaogn",
  "license": "MIT",
  "homepage": "https://github.com/liaogn/react-drag-resize-rotate#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/liaogn/react-drag-resize-rotate.git"
  },
  "bugs": {
    "url": "https://github.com/liaogn/react-drag-resize-rotate/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build --mode lib",
    "preview": "vite preview",
    "type-check": "tsc --noEmit",
    "lint": "eslint .",
    "docs:dev": "docusaurus start docs",
    "docs:dev:en": "docusaurus start docs --locale en",
    "docs:build": "docusaurus build docs",
    "docs:preview": "docusaurus serve docs --dir build",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "peerDependencies": {
    "react": "^18.2.0 || ^19.0.0",
    "react-dom": "^18.2.0 || ^19.0.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@docusaurus/core": "^3.10.1",
    "@docusaurus/preset-classic": "^3.10.1",
    "@docusaurus/tsconfig": "^3.10.1",
    "@docusaurus/types": "^3.10.1",
    "@eslint/js": "^10.0.1",
    "@microsoft/api-extractor": "^7.55.1",
    "@types/node": "^22.10.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.4.0",
    "prism-react-renderer": "^2.4.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^8.0.12",
    "vite-plugin-dts": "^5.0.0"
  }
}
